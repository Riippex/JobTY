# ─────────────────────────────────────────────
# JobTY — Environment Variables Reference
# Copy this file to .env and fill in your values.
# Never commit the real .env file.
# ─────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────
# Which LLM backend to use: openai | groq | anthropic | gemini | ollama
LLM_PROVIDER=openai

# OpenAI (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1

# Groq (required if LLM_PROVIDER=groq)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Gemini (required if LLM_PROVIDER=gemini)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# Ollama — local models, no API key needed (required if LLM_PROVIDER=ollama)
# Use host.docker.internal instead of localhost when running inside Docker
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Backend ────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Database ───────────────────────────────────
# SQLite for development. Switch to PostgreSQL for production:
# postgresql+asyncpg://user:password@host:5432/jobty
DATABASE_URL=sqlite+aiosqlite:///./jobty.db

# ── Frontend ───────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ── Playwright / Bot ───────────────────────────
# Set to false during development to watch the browser in action
PLAYWRIGHT_HEADLESS=true
# Add delay (ms) between actions — useful for debugging (e.g. 100)
PLAYWRIGHT_SLOW_MO=0
# Milliseconds before an action times out
PLAYWRIGHT_TIMEOUT=30000

# ── Job Boards ─────────────────────────────────
ENABLED_BOARDS=linkedin,indeed
# Keep this low (5) while testing to avoid getting your account flagged
MAX_APPLICATIONS_PER_RUN=20

LINKEDIN_EMAIL=your@email.com
LINKEDIN_PASSWORD=your_password

# ── Application ────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
